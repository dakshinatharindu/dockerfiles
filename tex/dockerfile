FROM ubuntu:22.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install TeX Live and required packages
RUN apt-get update && apt-get install -y \
    python3-pip python3-pygments

RUN apt-get install -y texlive-full

# Set working directory
WORKDIR /latex

# Copy your LaTeX project files
COPY . /latex

# Create minted cache directory
RUN mkdir -p /latex/.minted-cache

# Compile command (run with shell-escape for minted)
CMD ["pdflatex", "-shell-escape", "-interaction=nonstopmode", "main.tex"]
